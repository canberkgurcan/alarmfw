# AlarmFW — Production Ortam Değişkenleri (Linux Host)
# Kullanım:
#   cp .env.prod.example .env
#   vi .env   # değerleri doldur
#   docker-compose -f docker-compose.prod.yml up -d
#
# .env git'e GÖNDERİLMEZ — sadece bu example dosyası commit edilir.

# ── Secrets dizini ────────────────────────────────────────────────────────────
# Host'ta token dosyalarının bulunduğu dizin
# İçeriği: <cluster>.token, <cluster>-prometheus.token vb.
SECRETS_DIR=/opt/alarmfw/secrets

# ── API Güvenlik Anahtarları ──────────────────────────────────────────────────
# Üretmek için: openssl rand -hex 32
ALARMFW_API_KEY=
ALARMFW_API_KEY_ADMIN=
ALARMFW_API_KEY_OPERATOR=
ALARMFW_API_KEY_READONLY=

# ── UI Auth ───────────────────────────────────────────────────────────────────
# Session şifreleme anahtarı — üretmek için: openssl rand -base64 32
AUTH_SECRET=

# UI giriş şifreleri
UI_ADMIN_PASSWORD=
UI_OPERATOR_PASSWORD=
UI_READONLY_PASSWORD=

# ── Zabbix ────────────────────────────────────────────────────────────────────
ZABBIX_URL=https://zabbix.internal
ZABBIX_TOKEN=

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=mailrelay.internal
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_TO=ops@sirket.com
