# AlarmFW — Ortam Değişkenleri
# Bu dosyayı kopyala: cp .env.example .env
# .env dosyası git'e gönderilmez.

# Token/secret dosyalarının bulunduğu dizin (docker-compose volume mount)
SECRETS_DIR=/path/to/alarmfw-secrets

# Zabbix
ZABBIX_URL=https://zabbix.internal
ZABBIX_TOKEN=

# SMTP
SMTP_HOST=mailrelay.internal
SMTP_PORT=25
SMTP_USER=alarmfw@sirket.com
SMTP_PASS=
SMTP_TO=ops@sirket.com
