# Yerel test için run config örneği.
# Bu dosyayı kopyalayıp run_local.yaml olarak kaydedin.
includes:
  - notifiers/zabbix.yaml
  - notifiers/smtp.yaml
  - notifiers/dev_outbox.yaml
  - notifiers/dev_smtp.yaml
  - policies/dedup.yaml
  - generated/ocp_pod_health.yaml

runtime:
  lock_file: "/state/alarmfw.lock"
  state_db: "/state/alarmfw.sqlite"
  log_level: "INFO"
  dry_run: false
  interval_sec: 60    # local test: 1 dakikada bir

clusters:
  - name: <cluster-name>
    server: "https://api.<cluster>.<domain>:6443"
    token_file: "/secrets/<cluster>.token"
    insecure_skip_tls_verify: true
